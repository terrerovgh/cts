---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SimpleGallery from '../components/SimpleGallery.astro';
import Servicios from '../components/Servicios.astro';
import ArtistJuan from '../components/ArtistJuan.astro';
import ArtistDavid from '../components/ArtistDavid.astro';
import ArtistNina from '../components/ArtistNina.astro';
import ArtistKarli from '../components/ArtistKarli.astro';
import Testimonios from '../components/Testimonios.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Hero />
  <SimpleGallery />
  <section id="servicios" class="relative py-20 bg-gray-800 text-white">
    <div class="container mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center">
        Servicios
      </h2>
      <div class="text-center">
        <p class="text-xl mb-8">Esta sección también funciona</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-gray-700 p-6 rounded-lg">
            <h3 class="text-xl font-bold mb-2">Tatuajes Custom</h3>
            <p class="text-gray-300">Diseños únicos y personalizados</p>
          </div>
          <div class="bg-gray-700 p-6 rounded-lg">
            <h3 class="text-xl font-bold mb-2">Restauración</h3>
            <p class="text-gray-300">Mejora de tatuajes existentes</p>
          </div>
          <div class="bg-gray-700 p-6 rounded-lg">
            <h3 class="text-xl font-bold mb-2">Consultoría</h3>
            <p class="text-gray-300">Asesoramiento artístico</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section id="tatuadores" class="section bg-black text-white py-20">
    <div class="container mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center">Tatuadores</h2>
      <div class="text-center">
        <p class="text-xl mb-8">Sección de tatuadores funcionando</p>
      </div>
    </div>
  </section>
  <section id="testimonios" class="relative py-20 bg-white text-black">
    <div class="container mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center text-black">
        Testimonios
      </h2>
      <div class="text-center">
        <p class="text-xl mb-8 text-gray-700">Esta sección también funciona</p>
      </div>
    </div>
  </section>
  <section id="contacto" class="relative py-20 bg-gray-900 text-white">
    <div class="container mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center">
        Contacto
      </h2>
      <div class="text-center">
        <p class="text-xl mb-8">Sección de contacto funcionando</p>
      </div>
    </div>
  </section>
</Layout>
