---
// Index ultra-simple sin layout ni componentes complejos
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cuba Tattoo Studio</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: #000;
            color: #fff;
            font-family: 'Arial', sans-serif;
            line-height: 1.6;
            overflow-x: hidden;
        }
        
        /* Asegurar que todo sea visible */
        section {
            position: relative;
            z-index: 10;
            padding: 80px 20px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            text-align: center;
            border: 2px solid rgba(255,255,255,0.2);
        }
        
        h1 {
            font-size: 4rem;
            margin-bottom: 2rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }
        
        h2 {
            font-size: 3rem;
            margin-bottom: 1.5rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }
        
        p {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            max-width: 800px;
        }
        
        .hero {
            background: linear-gradient(135deg, #000 0%, #333 50%, #000 100%);
        }
        
        .gallery {
            background: linear-gradient(135deg, #fff 0%, #f0f0f0 50%, #fff 100%);
            color: #000;
        }
        
        .services {
            background: linear-gradient(135deg, #333 0%, #666 50%, #333 100%);
        }
        
        .contact {
            background: linear-gradient(135deg, #000 0%, #111 50%, #000 100%);
        }
        
        .status {
            position: fixed;
            top: 20px;
            right: 20px;
            background: green;
            color: white;
            padding: 10px 20px;
            border-radius: 5px;
            z-index: 1000;
            font-weight: bold;
        }
        
        .nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: rgba(0,0,0,0.9);
            padding: 20px;
            z-index: 999;
            text-align: center;
        }
        
        .nav a {
            color: white;
            text-decoration: none;
            margin: 0 20px;
            font-size: 1.2rem;
        }
        
        .nav a:hover {
            color: yellow;
        }
    </style>
</head>
<body>
    <div class="status">✅ SITIO FUNCIONANDO</div>
    
    <nav class="nav">
        <a href="#hero">INICIO</a>
        <a href="#gallery">GALERÍA</a>
        <a href="#services">SERVICIOS</a>
        <a href="#contact">CONTACTO</a>
    </nav>
    
    <section id="hero" class="hero">
        <h1>🔥 CUBA TATTOO STUDIO 🔥</h1>
        <p>Arte en la piel, contado en cada trazo</p>
        <p>✅ Sección Hero funcionando correctamente</p>
        <p>Si puedes leer esto, el sitio está cargando bien</p>
    </section>
    
    <section id="gallery" class="gallery">
        <h2>🎨 GALERÍA DE TRABAJOS 🎨</h2>
        <p>Aquí se mostrará la galería de tatuajes</p>
        <p>✅ Sección Gallery funcionando correctamente</p>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; width: 100%; max-width: 800px; margin-top: 40px;">
            <div style="background: #ddd; color: #000; padding: 20px; border-radius: 10px;">
                <h3>Trabajo 1</h3>
                <p>Descripción del trabajo</p>
            </div>
            <div style="background: #ddd; color: #000; padding: 20px; border-radius: 10px;">
                <h3>Trabajo 2</h3>
                <p>Descripción del trabajo</p>
            </div>
            <div style="background: #ddd; color: #000; padding: 20px; border-radius: 10px;">
                <h3>Trabajo 3</h3>
                <p>Descripción del trabajo</p>
            </div>
        </div>
    </section>
    
    <section id="services" class="services">
        <h2>💼 SERVICIOS 💼</h2>
        <p>Nuestros servicios de tatuaje profesional</p>
        <p>✅ Sección Services funcionando correctamente</p>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px; width: 100%; max-width: 900px; margin-top: 40px;">
            <div style="background: rgba(255,255,255,0.1); padding: 30px; border-radius: 10px;">
                <h3>Tatuajes Custom</h3>
                <p>Diseños únicos y personalizados</p>
            </div>
            <div style="background: rgba(255,255,255,0.1); padding: 30px; border-radius: 10px;">
                <h3>Restauración</h3>
                <p>Mejora de tatuajes existentes</p>
            </div>
            <div style="background: rgba(255,255,255,0.1); padding: 30px; border-radius: 10px;">
                <h3>Consultoría</h3>
                <p>Asesoramiento artístico</p>
            </div>
        </div>
    </section>
    
    <section id="contact" class="contact">
        <h2>📞 CONTACTO 📞</h2>
        <p>Ponte en contacto con nosotros</p>
        <p>✅ Sección Contact funcionando correctamente</p>
        <div style="margin-top: 40px;">
            <p>📧 Email: info@cubatattoostudio.com</p>
            <p>📱 Teléfono: +53 1234 5678</p>
            <p>📍 La Habana, Cuba</p>
        </div>
    </section>
    
    <script>
        console.log('🚀 Cuba Tattoo Studio - Página principal cargada');
        console.log('✅ JavaScript funcionando correctamente');
        
        // Smooth scroll para navegación
        document.querySelectorAll('.nav a').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                    console.log('🔄 Navegando a:', this.getAttribute('href'));
                }
            });
        });
        
        // Indicator de estado
        let counter = 0;
        setInterval(() => {
            counter++;
            const status = document.querySelector('.status');
            if (status) {
                status.textContent = `✅ ACTIVO ${counter}`;
            }
            console.log(`💓 Heartbeat ${counter}`);
        }, 2000);
        
        // Log de secciones visibles
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    console.log('👁️ Sección visible:', entry.target.id);
                }
            });
        });
        
        document.querySelectorAll('section').forEach(section => {
            observer.observe(section);
        });
    </script>
</body>
</html>
