---
import Layout from '../layouts/Layout.astro';
import HeroAdvanced from '../components/HeroAdvanced.astro';
import ArtistDavidHorizontal from '../components/ArtistDavidHorizontal.astro';
import ArtistJuanHorizontal from '../components/ArtistJuanHorizontal.astro';
import ArtistKarliHorizontal from '../components/ArtistKarliHorizontal.astro';
import ArtistNinaHorizontal from '../components/ArtistNinaHorizontal.astro';
---

<Layout title="Cuba Tattoo Studio" description="Arte en la piel, contado en cada trazo">
  <!-- Hero Section Avanzado con GSAP -->
  <HeroAdvanced />

  <!-- Gallery Section Simplificado -->
  <section id="gallery" class="relative py-20 bg-white text-black">
    <div class="container mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center">
        Galería de Trabajos
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-gray-100 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow group">
          <img 
            src="https://images.unsplash.com/photo-1611501275019-9b5cda994e8d?w=600&h=400&fit=crop&crop=center" 
            alt="Tatuaje Biomecánico" 
            class="h-64 w-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Tatuaje Biomecánico</h3>
            <p class="text-gray-600">Fusión entre lo orgánico y lo mecánico</p>
          </div>
        </div>
        
        <div class="bg-gray-100 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow group">
          <img 
            src="https://images.unsplash.com/photo-1590736969955-71cc94901144?w=600&h=400&fit=crop&crop=center" 
            alt="Realismo en Blanco y Negro" 
            class="h-64 w-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Realismo en Blanco y Negro</h3>
            <p class="text-gray-600">Técnica fotorealista en escala de grises</p>
          </div>
        </div>
        
        <div class="bg-gray-100 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow group">
          <img 
            src="https://images.unsplash.com/photo-1565058379802-bbe93b2f703a?w=600&h=400&fit=crop&crop=center" 
            alt="Arte Tradicional" 
            class="h-64 w-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Arte Tradicional</h3>
            <p class="text-gray-600">Diseños clásicos con un toque moderno</p>
          </div>
        </div>
        
        <div class="bg-gray-100 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow group">
          <img 
            src="https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=600&h=400&fit=crop&crop=center" 
            alt="Tatuaje Minimalista" 
            class="h-64 w-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Minimalista</h3>
            <p class="text-gray-600">Líneas limpias y diseños simples</p>
          </div>
        </div>
        
        <div class="bg-gray-100 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow group">
          <img 
            src="https://images.unsplash.com/photo-1618453292831-9ac5b7049ddd?w=600&h=400&fit=crop&crop=center" 
            alt="Tatuaje Acuarela" 
            class="h-64 w-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Acuarela</h3>
            <p class="text-gray-600">Efectos de acuarela únicos</p>
          </div>
        </div>
        
        <div class="bg-gray-100 rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow group">
          <img 
            src="https://images.unsplash.com/photo-1598378667002-b9b67ac5ef0b?w=600&h=400&fit=crop&crop=center" 
            alt="Tatuaje Geométrico" 
            class="h-64 w-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Geométrico</h3>
            <p class="text-gray-600">Patrones y formas geométricas</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="servicios" class="relative py-20 bg-gray-900 text-white">
    <div class="container mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center">
        Servicios
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-gray-800 p-8 rounded-lg text-center hover:bg-gray-700 transition-colors">
          <div class="text-4xl mb-4">🎨</div>
          <h3 class="text-2xl font-bold mb-4">Tatuajes Custom</h3>
          <p class="text-gray-300">Diseños únicos y personalizados creados especialmente para ti</p>
        </div>
        
        <div class="bg-gray-800 p-8 rounded-lg text-center hover:bg-gray-700 transition-colors">
          <div class="text-4xl mb-4">🔧</div>
          <h3 class="text-2xl font-bold mb-4">Restauración</h3>
          <p class="text-gray-300">Mejoramos y restauramos tatuajes existentes con técnicas avanzadas</p>
        </div>
        
        <div class="bg-gray-800 p-8 rounded-lg text-center hover:bg-gray-700 transition-colors">
          <div class="text-4xl mb-4">💡</div>
          <h3 class="text-2xl font-bold mb-4">Consultoría</h3>
          <p class="text-gray-300">Asesoramiento artístico profesional para tu próximo tatuaje</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Artists Section -->
  <section id="tatuadores" class="relative py-20 bg-black text-white">
    <div class="container mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center">
        Tatuadores
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center group">
          <img 
            src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300&h=300&fit=crop&crop=face" 
            alt="Juan - Tatuador" 
            class="w-32 h-32 rounded-full mx-auto mb-4 object-cover border-4 border-gray-600 group-hover:border-white transition-colors"
          />
          <h3 class="text-xl font-bold mb-2">Juan</h3>
          <p class="text-gray-400">Especialista en Biomecánico</p>
        </div>
        
        <div class="text-center group">
          <img 
            src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=300&h=300&fit=crop&crop=face" 
            alt="David - Tatuador" 
            class="w-32 h-32 rounded-full mx-auto mb-4 object-cover border-4 border-gray-600 group-hover:border-white transition-colors"
          />
          <h3 class="text-xl font-bold mb-2">David</h3>
          <p class="text-gray-400">Maestro del Realismo</p>
        </div>
        
        <div class="text-center group">
          <img 
            src="https://images.unsplash.com/photo-1494790108755-2616b612b1ab?w=300&h=300&fit=crop&crop=face" 
            alt="Nina - Tatuadora" 
            class="w-32 h-32 rounded-full mx-auto mb-4 object-cover border-4 border-gray-600 group-hover:border-white transition-colors"
          />
          <h3 class="text-xl font-bold mb-2">Nina</h3>
          <p class="text-gray-400">Experta en Acuarela</p>
        </div>
        
        <div class="text-center group">
          <img 
            src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=300&h=300&fit=crop&crop=face" 
            alt="Karli - Tatuadora" 
            class="w-32 h-32 rounded-full mx-auto mb-4 object-cover border-4 border-gray-600 group-hover:border-white transition-colors"
          />
          <h3 class="text-xl font-bold mb-2">Karli</h3>
          <p class="text-gray-400">Diseños Minimalistas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section id="testimonios" class="relative py-20 bg-white text-black">
    <div class="container mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center">
        Testimonios
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-gray-100 p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow">
          <p class="text-gray-700 mb-4 italic">"Increíble trabajo, superó todas mis expectativas. El equipo es muy profesional."</p>
          <div class="flex items-center">
            <img 
              src="https://images.unsplash.com/photo-1494790108755-2616b612b1ab?w=100&h=100&fit=crop&crop=face" 
              alt="María González" 
              class="w-12 h-12 rounded-full mr-4 object-cover"
            />
            <div>
              <p class="font-bold">María González</p>
              <p class="text-gray-600 text-sm">Cliente satisfecha</p>
            </div>
          </div>
        </div>
        
        <div class="bg-gray-100 p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow">
          <p class="text-gray-700 mb-4 italic">"El mejor estudio de tatuajes en La Habana. Calidad excepcional y trato personalizado."</p>
          <div class="flex items-center">
            <img 
              src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face" 
              alt="Carlos Pérez" 
              class="w-12 h-12 rounded-full mr-4 object-cover"
            />
            <div>
              <p class="font-bold">Carlos Pérez</p>
              <p class="text-gray-600 text-sm">Cliente regular</p>
            </div>
          </div>
        </div>
        
        <div class="bg-gray-100 p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow">
          <p class="text-gray-700 mb-4 italic">"Arte puro en cada trazo. Mi tatuaje es exactamente lo que soñaba."</p>
          <div class="flex items-center">
            <img 
              src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop&crop=face" 
              alt="Ana Rodríguez" 
              class="w-12 h-12 rounded-full mr-4 object-cover"
            />
            <div>
              <p class="font-bold">Ana Rodríguez</p>
              <p class="text-gray-600 text-sm">Cliente nueva</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contacto" class="relative py-20 bg-gray-900 text-white">
    <div class="container mx-auto px-6">
      <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center">
        Contacto
      </h2>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-bold mb-6">Ponte en contacto</h3>
          <div class="space-y-4">
            <div class="flex items-center">
              <span class="text-2xl mr-4">📧</span>
              <div>
                <p class="font-bold">Email</p>
                <p class="text-gray-400">info@cubatattoostudio.com</p>
              </div>
            </div>
            
            <div class="flex items-center">
              <span class="text-2xl mr-4">📱</span>
              <div>
                <p class="font-bold">Teléfono</p>
                <p class="text-gray-400">+53 1234 5678</p>
              </div>
            </div>
            
            <div class="flex items-center">
              <span class="text-2xl mr-4">📍</span>
              <div>
                <p class="font-bold">Ubicación</p>
                <p class="text-gray-400">La Habana, Cuba</p>
              </div>
            </div>
            
            <div class="flex items-center">
              <span class="text-2xl mr-4">🕒</span>
              <div>
                <p class="font-bold">Horarios</p>
                <p class="text-gray-400">Lun-Sáb: 10:00 - 20:00</p>
              </div>
            </div>
          </div>
        </div>
        
        <div>
          <h3 class="text-2xl font-bold mb-6">Reserva tu cita</h3>
          <form class="space-y-4">
            <input 
              type="text" 
              placeholder="Tu nombre" 
              class="w-full p-3 rounded bg-gray-800 text-white border border-gray-700 focus:border-white focus:outline-none"
            />
            <input 
              type="email" 
              placeholder="Tu email" 
              class="w-full p-3 rounded bg-gray-800 text-white border border-gray-700 focus:border-white focus:outline-none"
            />
            <textarea 
              placeholder="Describe tu idea de tatuaje" 
              rows="4"
              class="w-full p-3 rounded bg-gray-800 text-white border border-gray-700 focus:border-white focus:outline-none"
            ></textarea>
            <button 
              type="submit" 
              class="w-full bg-white text-black p-3 rounded font-bold hover:bg-gray-200 transition-colors"
            >
              Enviar mensaje
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-black text-white py-8">
    <div class="container mx-auto px-6 text-center">
      <p class="text-gray-400">&copy; 2025 Cuba Tattoo Studio. Todos los derechos reservados.</p>
    </div>
  </footer>
</Layout>

<style>
  /* Fuente Rye para títulos */
  h1, h2, h3, .font-rye {
    font-family: 'Rye', cursive, sans-serif;
    letter-spacing: 0.04em;
  }
</style>
