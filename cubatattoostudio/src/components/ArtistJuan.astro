---
import ArtistBase from './ArtistBase.astro';

// Props específicos para Juan
const trabajos = [
  { tipo: 'image' as const, src: "https://images.unsplash.com/photo-1611501275019-9b5cda994e8d?w=800&h=800&fit=crop", alt: "Retrato Realista" },
  { tipo: 'video' as const, src: "https://www.w3schools.com/html/mov_bbb.mp4", alt: "Proceso de Trabajo" },
  { tipo: 'image' as const, src: "https://images.unsplash.com/photo-1565058379802-bbe93b2f703a?w=800&h=800&fit=crop", alt: "Retrato Detallado" },
  { tipo: 'image' as const, src: "https://images.unsplash.com/photo-1590736969955-71cc94901144?w=800&h=800&fit=crop", alt: "Arte Realista" },
  { tipo: 'video' as const, src: "https://www.w3schools.com/html/mov_bbb.mp4", alt: "Técnica Avanzada" },
  { tipo: 'image' as const, src: "https://images.unsplash.com/photo-1598300042247-d088f8ab3a91?w=800&h=800&fit=crop", alt: "Masterpiece Final" },
  { tipo: 'image' as const, src: "https://images.unsplash.com/photo-1611501275019-9b5cda994e8d?w=600&h=800&fit=crop", alt: "Retrato Clásico" },
  { tipo: 'video' as const, src: "https://www.w3schools.com/html/mov_bbb.mp4", alt: "Making Of" }
];
---

<ArtistBase
  id="juan"
  nombre="Juan Pérez"
  video="https://www.w3schools.com/html/mov_bbb.mp4"
  descripcion="Especialista en realismo y retratos. Más de 10 años creando arte en la piel con técnicas tradicionales y modernas."
  trabajos={trabajos}
  accentColor="#ff6b35"
/>
