---
---
<div id="preloader" class="fixed inset-0 flex items-center justify-center bg-black z-50">
  <div class="w-10 h-10 border-4 border-white rounded-full animate-spin"></div>
</div>
<section id="hero" class="relative flex items-center justify-center text-center text-white min-h-screen overflow-hidden bg-black">
  <video class="absolute inset-0 w-full h-full object-cover" src="/assets/hero.mp4" autoplay muted loop playsinline></video>
  <div class="relative z-10 content">
    <h2 class="text-5xl font-bold mb-4">Cuba Tattoo Studio</h2>
    <p class="text-xl">Arte en la piel, contado en cada trazo.</p>
  </div>
</section>

<script client:load type="module">
  import gsap from 'gsap';
  window.addEventListener('load', () => {
    const tl = gsap.timeline();
    tl.to('#preloader', { opacity: 0, duration: 0.5, onComplete: () => {
      const p = document.getElementById('preloader');
      if (p) p.remove();
    }});
    tl.from('#hero .content', { y: 50, opacity: 0, duration: 1 });
  });
</script>
