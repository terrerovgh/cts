---
---

<section id="hero" class="section min-h-screen flex flex-col justify-center items-center bg-black text-white relative overflow-hidden">
  <div class="absolute inset-0 w-full h-full z-0">
    <video class="w-full h-full object-cover opacity-70" src="/assets/hero.mp4" autoplay loop muted playsinline poster="/assets/logo.png"></video>
    <div class="absolute inset-0 bg-gradient-to-b from-black/80 to-black/60"></div>
  </div>
  <div class="relative z-10 flex flex-col items-center justify-center gap-8 pt-32 pb-16">
    <img src="/assets/logo.png" alt="Logo Cuba Tattoo Studio" class="h-24 w-auto drop-shadow-2xl animate-fade-in" style="max-width:120px;" />
    <h1 class="text-5xl md:text-7xl font-rye font-bold text-white drop-shadow-lg animate-fade-in delay-100">Arte en la piel, contado en cada trazo</h1>
    <p class="text-xl md:text-2xl text-gray-200 mt-4 animate-fade-in delay-200">Tatuajes de autor en La Habana</p>
    <span class="mt-10 animate-bounce text-3xl text-white/80">↓</span>
  </div>
</section>
<style>
@keyframes fade-in {
  from { opacity: 0; transform: translateY(40px); }
  to { opacity: 1; transform: none; }
}
.animate-fade-in {
  animation: fade-in 1.1s cubic-bezier(.4,0,.2,1) both;
}
.animate-fade-in.delay-100 { animation-delay: 0.1s; }
.animate-fade-in.delay-200 { animation-delay: 0.2s; }
</style>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

function lerp(a, b, n) {
  return (1 - n) * a + n * b;
}

window.addEventListener('DOMContentLoaded', () => {
  const video = document.getElementById('hero-video');
  const pin = document.querySelector('#video_scrub_01 .pinned-container');
  const content = document.getElementById('hero-content');

  if (!(video instanceof HTMLVideoElement) || !pin || !content) return;

  let targetTime = 0;
  let currentTime = 0;
  let rafId;

  function updateVideo() {
    const vid = video as HTMLVideoElement | null;
    if (vid && typeof vid.currentTime === 'number') {
      currentTime = lerp(currentTime, targetTime, 0.2);
      vid.currentTime = currentTime;
    }
    rafId = requestAnimationFrame(updateVideo);
  }

  video.addEventListener('loadedmetadata', () => {
    const scrubDuration = window.innerHeight * 3;
    video.currentTime = 0;
    video.pause();
    currentTime = 0;
    targetTime = 0;
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(updateVideo);

    ScrollTrigger.create({
      trigger: pin,
      start: 'top top',
      end: `+=${scrubDuration}`,
      pin: true,
      scrub: true,
      anticipatePin: 1,
      onUpdate: self => {
        const progress = self.progress;
        targetTime = progress * (video.duration || 1);
        if (progress > 0.95) {
          gsap.to(content, { opacity: 1, duration: 0.7, overwrite: 'auto' });
        } else {
          gsap.to(content, { opacity: 0, duration: 0.4, overwrite: 'auto' });
        }
      },
      onLeave: () => {
        if (rafId) cancelAnimationFrame(rafId);
      },
      onEnterBack: () => {
        if (rafId) cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(updateVideo);
      }
    });
  });
});
</script>
