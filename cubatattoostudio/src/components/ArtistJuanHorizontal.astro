---
// Artista Juan - Tradicional con efectos vintage
---

<section id="artist-juan" class="artist-section relative min-h-screen bg-gradient-to-br from-amber-900/20 via-black to-amber-900/20 overflow-hidden">
  <!-- Artist Horizontal Content Wrapper -->
  <div class="artist-content-wrapper flex" style="width: 400vw;">
    
    <!-- Panel 1: Introducción -->
    <div class="artist-panel w-screen min-h-screen flex items-center justify-center px-8">
      <div class="text-center max-w-4xl">
        <div class="artist-avatar mb-8">
          <img 
            src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=300&h=300&fit=crop&crop=face" 
            alt="Juan" 
            class="w-40 h-40 mx-auto rounded-full object-cover border-4 border-amber-500 shadow-2xl"
          />
        </div>
        <h2 class="text-6xl md:text-8xl font-rye font-bold text-white mb-6">JUAN</h2>
        <p class="text-2xl text-amber-300 mb-4">Maestro del Estilo Tradicional</p>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto leading-relaxed">
          Guardián de la tradición del tatuaje old school. Líneas sólidas, colores vibrantes 
          y diseños atemporales que honran la historia del arte en la piel.
        </p>
      </div>
    </div>

    <!-- Panel 2: Portfolio Principal -->
    <div class="artist-panel w-screen min-h-screen flex items-center justify-center px-8">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 max-w-6xl">
        <div class="artwork group">
          <img 
            src="https://images.unsplash.com/photo-1590246814883-57c511f96c5d?w=400&h=400&fit=crop" 
            alt="Tradicional 1" 
            class="w-full h-64 object-cover rounded-lg shadow-2xl group-hover:scale-105 transition-transform duration-500 filter sepia-[0.3] contrast-[1.1]"
          />
        </div>
        <div class="artwork group">
          <img 
            src="https://images.unsplash.com/photo-1611605698323-b1e99cfd37ea?w=400&h=400&fit=crop" 
            alt="Tradicional 2" 
            class="w-full h-64 object-cover rounded-lg shadow-2xl group-hover:scale-105 transition-transform duration-500 filter sepia-[0.3] contrast-[1.1]"
          />
        </div>
        <div class="artwork group">
          <img 
            src="https://images.unsplash.com/photo-1565058379802-bbe93b2986a5?w=400&h=400&fit=crop" 
            alt="Tradicional 3" 
            class="w-full h-64 object-cover rounded-lg shadow-2xl group-hover:scale-105 transition-transform duration-500 filter sepia-[0.3] contrast-[1.1]"
          />
        </div>
        <div class="artwork group">
          <img 
            src="https://images.unsplash.com/photo-1598300042247-d088f8ab3a91?w=400&h=400&fit=crop" 
            alt="Tradicional 4" 
            class="w-full h-64 object-cover rounded-lg shadow-2xl group-hover:scale-105 transition-transform duration-500 filter sepia-[0.3] contrast-[1.1]"
          />
        </div>
        <div class="artwork group">
          <img 
            src="https://images.unsplash.com/photo-1590246814883-57c511f96c5d?w=400&h=400&fit=crop" 
            alt="Tradicional 5" 
            class="w-full h-64 object-cover rounded-lg shadow-2xl group-hover:scale-105 transition-transform duration-500 filter sepia-[0.3] contrast-[1.1]"
          />
        </div>
        <div class="artwork group">
          <img 
            src="https://images.unsplash.com/photo-1565058379802-bbe93b2986a5?w=400&h=400&fit=crop" 
            alt="Tradicional 6" 
            class="w-full h-64 object-cover rounded-lg shadow-2xl group-hover:scale-105 transition-transform duration-500 filter sepia-[0.3] contrast-[1.1]"
          />
        </div>
      </div>
    </div>

    <!-- Panel 3: Filosofía Old School -->
    <div class="artist-panel w-screen min-h-screen flex items-center justify-center px-8">
      <div class="grid md:grid-cols-2 gap-12 max-w-6xl items-center">
        <div>
          <h3 class="text-4xl font-rye font-bold text-amber-400 mb-6">Old School Forever</h3>
          <div class="space-y-6">
            <div class="tradition-element">
              <h4 class="text-xl font-bold text-white mb-2">Líneas Sólidas</h4>
              <p class="text-gray-300">Cada trazo es firme y decidido, siguiendo la tradición de los grandes maestros.</p>
            </div>
            <div class="tradition-element">
              <h4 class="text-xl font-bold text-white mb-2">Colores Clásicos</h4>
              <p class="text-gray-300">Paleta tradicional: rojos vibrantes, azules profundos, verdes intensos.</p>
            </div>
            <div class="tradition-element">
              <h4 class="text-xl font-bold text-white mb-2">Diseños Atemporales</h4>
              <p class="text-gray-300">Motivos que han perdurado décadas: anclas, golondrinas, rosas, corazones.</p>
            </div>
          </div>
        </div>
        <div class="artwork group">
          <img 
            src="https://images.unsplash.com/photo-1598300042247-d088f8ab3a91?w=600&h=400&fit=crop" 
            alt="Filosofía de Juan" 
            class="w-full rounded-lg shadow-2xl group-hover:scale-105 transition-transform duration-500 filter sepia-[0.4] contrast-[1.2]"
          />
        </div>
      </div>
    </div>

    <!-- Panel 4: Contacto & Estilo -->
    <div class="artist-panel w-screen min-h-screen flex items-center justify-center px-8">
      <div class="text-center max-w-4xl">
        <h3 class="text-5xl font-rye font-bold text-amber-400 mb-8">Tradición en Cada Trazo</h3>
        <p class="text-xl text-gray-300 mb-12 max-w-2xl mx-auto">
          Si buscas un tatuaje con historia, que respete los códigos del tatuaje tradicional, 
          has llegado al lugar correcto.
        </p>
        
        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <div class="contact-info">
            <h4 class="text-2xl font-bold text-white mb-4">Disponibilidad</h4>
            <p class="text-gray-300 mb-2">Martes a Sábado: 11:00 - 19:00</p>
            <p class="text-gray-300 mb-2">Domingos: 12:00 - 17:00</p>
            <p class="text-gray-300">Lunes: Descanso</p>
          </div>
          <div class="contact-info">
            <h4 class="text-2xl font-bold text-white mb-4">Especialidades</h4>
            <p class="text-gray-300 mb-2">• American Traditional</p>
            <p class="text-gray-300 mb-2">• Neo Traditional</p>
            <p class="text-gray-300">• Flash Clásico</p>
          </div>
        </div>

        <button class="bg-amber-600 hover:bg-amber-700 text-white px-8 py-4 text-xl font-bold rounded-lg transition-colors shadow-lg">
          Agendar con Juan
        </button>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 right-8 text-white/70 z-30">
    <span class="text-sm uppercase tracking-wider">Desliza →</span>
  </div>
</section>

<style>
  .artist-section {
    position: relative;
  }
  
  .artist-content-wrapper {
    display: flex;
    will-change: transform;
  }
  
  .artist-panel {
    flex-shrink: 0;
  }
  
  .artwork {
    transform: perspective(1000px);
  }
  
  .tradition-element {
    padding-left: 20px;
    border-left: 2px solid #d97706;
  }
  
  /* Efectos vintage automáticos */
  .artist-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(circle at 20% 20%, rgba(217, 119, 6, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(217, 119, 6, 0.1) 0%, transparent 50%);
    pointer-events: none;
    z-index: 1;
  }
</style>
