---
// Props: contacto (objeto con email, telefono, direccion)
const { contacto = { email: 'info@cubatattoostudio.com', telefono: '+53 5555 5555', direccion: 'Calle 23 #123, La Habana, Cuba' } } = Astro.props;
---

<section id="contacto" class="section py-24 md:py-36 bg-white text-black">
  <div class="container mx-auto max-w-2xl">
    <h2 class="text-4xl md:text-5xl font-rye font-bold mb-8 text-center">Contacto</h2>
    <form class="flex flex-col gap-6 bg-gray-50 rounded-xl shadow-lg p-8" name="contacto" method="POST" action="https://formspree.io/f/mnqkzjzj">
      <input type="text" name="nombre" placeholder="Nombre" required class="form-input border border-black rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-black" />
      <input type="email" name="email" placeholder="Email" required class="form-input border border-black rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-black" />
      <textarea name="mensaje" placeholder="Mensaje" required rows="4" class="form-textarea border border-black rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-black"></textarea>
      <button type="submit" class="bg-black text-white font-bold py-3 rounded-lg hover:bg-gray-800 transition">Enviar</button>
    </form>
    <div class="flex flex-col md:flex-row justify-center items-center gap-6 mt-8 text-center">
      <div class="flex items-center gap-2"><span class="font-bold">Email:</span> <a href={`mailto:${contacto.email}`} class="underline">{contacto.email}</a></div>
      <div class="flex items-center gap-2"><span class="font-bold">Teléfono:</span> <a href={`tel:${contacto.telefono}`} class="underline">{contacto.telefono}</a></div>
      <div class="flex items-center gap-2"><span class="font-bold">Dirección:</span> <span>{contacto.direccion}</span></div>
    </div>
  </div>
</section>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);
window.addEventListener('DOMContentLoaded', () => {
  gsap.from('form', {
    opacity: 0,
    y: 60,
    duration: 0.8,
    scrollTrigger: {
      trigger: 'form',
      start: 'top 85%',
      toggleActions: 'play none none none',
    }
  });
});
</script>
