---
// Datos de muestra para la galería
const galleryItems = [
  {
    id: 1,
    image: "https://images.unsplash.com/photo-1611501275019-9b5cda994e8d?w=800&h=800&fit=crop",
    alt: "Tatuaje de estilo realista",
    category: "Realismo",
    artist: "Juan"
  },
  {
    id: 2,
    image: "https://images.unsplash.com/photo-1565058379802-bbe93b2f703a?w=800&h=800&fit=crop",
    alt: "Tatuaje tradicional",
    category: "Tradicional",
    artist: "María"
  },
  {
    id: 3,
    image: "https://images.unsplash.com/photo-1590736969955-71cc94901144?w=800&h=800&fit=crop",
    alt: "Tatuaje geométrico",
    category: "Geométrico",
    artist: "Carlos"
  },
  {
    id: 4,
    image: "https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=800&h=800&fit=crop",
    alt: "Tatuaje neo-tradicional",
    category: "Neo-tradicional",
    artist: "Ana"
  },
  {
    id: 5,
    image: "https://images.unsplash.com/photo-1590736969955-71cc94901144?w=800&h=800&fit=crop",
    alt: "Tatuaje minimalista",
    category: "Minimalista",
    artist: "Luis"
  },
  {
    id: 6,
    image: "https://images.unsplash.com/photo-1611501275019-9b5cda994e8d?w=800&h=800&fit=crop",
    alt: "Tatuaje blackwork",
    category: "Blackwork",
    artist: "Sofia"
  },
  {
    id: 7,
    image: "https://images.unsplash.com/photo-1565058379802-bbe93b2f703a?w=800&h=800&fit=crop",
    alt: "Tatuaje abstracto",
    category: "Abstracto",
    artist: "Diego"
  },
  {
    id: 8,
    image: "https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=800&h=800&fit=crop",
    alt: "Tatuaje dotwork",
    category: "Dotwork",
    artist: "Elena"
  }
];

const categories = ["Todos", ...new Set(galleryItems.map(item => item.category))];
---

<section id="galeria" class="py-20 bg-white">
  <div class="container mx-auto px-6">
    <!-- Título de sección -->
    <div class="text-center mb-16">
      <h2 class="section-title text-4xl md:text-6xl font-black text-black mb-4 opacity-0">
        TRABAJOS DESTACADOS
      </h2>
      <div class="section-line w-24 h-1 bg-black mx-auto opacity-0"></div>
      <p class="section-subtitle text-gray-600 mt-6 text-lg opacity-0">
        Una selección de nuestros mejores trabajos
      </p>
    </div>

    <!-- Filtros de categoría -->
    <div class="filter-container flex flex-wrap justify-center gap-4 mb-12 opacity-0">
      {categories.map((category) => (
        <button 
          class="filter-btn px-6 py-2 border-2 border-black text-black hover:bg-black hover:text-white transition-all duration-300 uppercase tracking-wide font-semibold"
          data-filter={category.toLowerCase()}
        >
          {category}
        </button>
      ))}
    </div>

    <!-- Grid de galería -->
    <div class="gallery-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {galleryItems.map((item, index) => (
        <div 
          class="gallery-item group relative overflow-hidden bg-black aspect-square cursor-pointer"
          data-category={item.category.toLowerCase()}
          data-index={index}
        >
          <!-- Imagen -->
          <img 
            src={item.image}
            alt={item.alt}
            class="w-full h-full object-cover transition-all duration-500 group-hover:scale-110 grayscale group-hover:grayscale-0"
            loading="lazy"
          />
          
          <!-- Overlay con información -->
          <div class="absolute inset-0 bg-black/80 opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
            <div class="text-center text-white p-4">
              <h3 class="text-xl font-bold mb-2">{item.category}</h3>
              <p class="text-sm text-gray-300">Por {item.artist}</p>
              <div class="mt-4">
                <span class="inline-block px-3 py-1 bg-white text-black text-xs font-semibold uppercase tracking-wide">
                  Ver Detalle
                </span>
              </div>
            </div>
          </div>

          <!-- Número de índice -->
          <div class="absolute top-4 left-4 w-8 h-8 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center text-white text-sm font-bold">
            {(index + 1).toString().padStart(2, '0')}
          </div>
        </div>
      ))}
    </div>

    <!-- Botón para ver más -->
    <div class="text-center mt-16">
      <button class="cta-button px-8 py-4 bg-black text-white hover:bg-white hover:text-black border-2 border-black transition-all duration-300 uppercase tracking-wide font-bold opacity-0">
        Ver Más Trabajos
      </button>
    </div>
  </div>
</section>

<!-- Modal para vista detallada (lightbox simple) -->
<div id="gallery-modal" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4">
  <div class="relative max-w-4xl max-h-full">
    <button id="close-modal" class="absolute -top-4 -right-4 w-8 h-8 bg-white text-black rounded-full flex items-center justify-center font-bold hover:bg-gray-200 transition-colors">
      ✕
    </button>
    <img id="modal-image" src="" alt="" class="max-w-full max-h-full object-contain" />
    <div id="modal-info" class="absolute bottom-0 left-0 right-0 bg-black/80 text-white p-4">
      <h3 id="modal-title" class="text-xl font-bold"></h3>
      <p id="modal-artist" class="text-gray-300"></p>
    </div>
  </div>
</div>

<style>
  .gallery-item {
    transform: translateY(60px);
    opacity: 0;
  }

  .section-title,
  .section-line,
  .section-subtitle,
  .filter-container,
  .cta-button {
    transform: translateY(40px);
  }

  .filter-btn.active {
    background-color: black;
    color: white;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('DOMContentLoaded', () => {
    // Fade-in y slide-up de la sección Galería
    gsap.from('#galeria', {
      opacity: 0,
      y: 100,
      duration: 1.2,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#galeria',
        start: 'top 80%',
        end: 'top 50%',
        scrub: true
      }
    });
    // Fade-in escalonado de las imágenes
    gsap.utils.toArray('.gallery-item').forEach((item, i) => {
      gsap.from(item as HTMLElement, {
        opacity: 0,
        y: 60,
        duration: 1,
        delay: i * 0.08,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: item as HTMLElement,
          start: 'top 90%',
          end: 'top 60%',
          scrub: true
        }
      });
    });
  });

  document.addEventListener('DOMContentLoaded', () => {
    // Animación de entrada de la sección
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#galeria",
        start: "top 80%",
        end: "bottom 20%",
        toggleActions: "play none none reverse"
      }
    });

    tl.to('.section-title', { y: 0, opacity: 1, duration: 0.8, ease: "power2.out" })
      .to('.section-line', { y: 0, opacity: 1, duration: 0.6, ease: "power2.out" }, "-=0.4")
      .to('.section-subtitle', { y: 0, opacity: 1, duration: 0.6, ease: "power2.out" }, "-=0.3")
      .to('.filter-container', { y: 0, opacity: 1, duration: 0.6, ease: "power2.out" }, "-=0.2");

    // Animación escalonada de las imágenes
    gsap.to('.gallery-item', {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.1,
      ease: "power2.out",
      scrollTrigger: {
        trigger: ".gallery-grid",
        start: "top 85%",
        toggleActions: "play none none reverse"
      }
    });

    // Animación del botón CTA
    gsap.to('.cta-button', {
      y: 0,
      opacity: 1,
      duration: 0.6,
      ease: "power2.out",
      scrollTrigger: {
        trigger: ".cta-button",
        start: "top 90%",
        toggleActions: "play none none reverse"
      }
    });

    // Sistema de filtros
    const filterButtons = document.querySelectorAll('.filter-btn');
    const galleryItems = document.querySelectorAll('.gallery-item');

    // Activar primer botón por defecto
    if (filterButtons.length > 0) filterButtons[0].classList.add('active');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');
        // Actualizar botones activos
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');
        // Filtrar elementos con animación
        galleryItems.forEach(item => {
          const category = item.getAttribute('data-category');
          if (filter === 'todos' || category === filter) {
            gsap.to(item as HTMLElement, { opacity: 1, scale: 1, duration: 0.4, ease: "power2.out" });
            if (item instanceof HTMLElement) item.style.display = 'block';
          } else {
            gsap.to(item as HTMLElement, {
              opacity: 0,
              scale: 0.8,
              duration: 0.3,
              ease: "power2.in",
              onComplete: () => {
                if (item instanceof HTMLElement) item.style.display = 'none';
              }
            });
          }
        });
      });
    });

    // Sistema de modal/lightbox
    const modal = document.getElementById('gallery-modal');
    const modalImage = document.getElementById('modal-image') as HTMLImageElement | null;
    const modalTitle = document.getElementById('modal-title') as HTMLElement | null;
    const modalArtist = document.getElementById('modal-artist') as HTMLElement | null;
    const closeModal = document.getElementById('close-modal');

    galleryItems.forEach(item => {
      item.addEventListener('click', () => {
        const img = item.querySelector('img') as HTMLImageElement | null;
        const category = item.getAttribute('data-category');
        // Datos del item (esto vendría de una fuente de datos real)
        const itemData = {
          image: img?.src || '',
          alt: img?.alt || '',
          category: category ? category.charAt(0).toUpperCase() + category.slice(1) : '',
          artist: (item.querySelector('.text-gray-300') as HTMLElement)?.textContent?.replace('Por ', '') || 'Artista'
        };
        if (modal && modalImage && modalTitle && modalArtist) {
          modalImage.src = itemData.image;
          modalImage.alt = itemData.alt;
          modalTitle.textContent = itemData.category;
          modalArtist.textContent = `Por ${itemData.artist}`;
          // Mostrar modal con animación
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          gsap.fromTo(modal,
            { opacity: 0 },
            { opacity: 1, duration: 0.3 }
          );
          const modalDiv = modal.querySelector('div');
          if (modalDiv) {
            gsap.fromTo(modalDiv,
              { scale: 0.8, opacity: 0 },
              { scale: 1, opacity: 1, duration: 0.4, ease: "back.out(1.7)" }
            );
          }
        }
      });
    });

    // Cerrar modal
    const closeModalFunction = () => {
      if (modal) {
        gsap.to(modal, {
          opacity: 0,
          duration: 0.3,
          onComplete: () => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
          }
        });
      }
    };

    if (closeModal) closeModal.addEventListener('click', closeModalFunction);
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeModalFunction();
        }
      });
    }
    // Cerrar con tecla Escape
    document.addEventListener('keydown', (e) => {
      if (modal && e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModalFunction();
      }
    });
  });
</script>
