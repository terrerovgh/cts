---
// Galería simplificada para debug
---

<section id="gallery" class="relative py-20 min-h-screen bg-white text-black">
  <div class="container mx-auto px-6">
    <h2 class="text-4xl md:text-5xl font-rye font-bold mb-16 text-center text-black">
      Galería de Trabajos
    </h2>
    
    <div class="text-center mb-12">
      <p class="text-xl text-gray-700 mb-8">
        Esta sección está funcionando correctamente
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2 text-black">Trabajo 1</h3>
          <p class="text-gray-600">Descripción del trabajo</p>
        </div>
        <div class="bg-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2 text-black">Trabajo 2</h3>
          <p class="text-gray-600">Descripción del trabajo</p>
        </div>
        <div class="bg-gray-200 p-6 rounded-lg">
          <h3 class="text-xl font-bold mb-2 text-black">Trabajo 3</h3>
          <p class="text-gray-600">Descripción del trabajo</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Asegurar que la galería sea visible */
  #gallery {
    background-color: white !important;
    color: black !important;
    z-index: 20;
    position: relative;
  }
  
  #gallery h2, #gallery h3 {
    color: black !important;
  }
  
  #gallery p {
    color: #4a5568 !important;
  }
</style>
